{
  "name": "john-ai-agentbox-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm vite --host 0.0.0.0",
    "build:dev": "pnpm vite build --mode development",
    "build": "tsc --noEmit --skipLibCheck && pnpm vite build && pnpm check:assets -- --compress",
    "preview": "vite preview --host 0.0.0.0",
    "check:assets": "node scripts/check-assets.mjs",
    "analyze:assets": "node scripts/check-assets.mjs --no-budget",
    "check:ui": "node scripts/check-ui-imports.mjs",
    "test:e2e": "HTTP_PROXY= HTTPS_PROXY= http_proxy= https_proxy= ALL_PROXY= all_proxy= playwright test",
    "test:e2e:ui": "HTTP_PROXY= HTTPS_PROXY= http_proxy= https_proxy= ALL_PROXY= all_proxy= playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-form": "^1.26.0",
    "@tanstack/react-table": "^8.21.3",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.8",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
